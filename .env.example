# ─── Server ──────────────────────────────────────────────────────────────
# Postgres connection string. Works with Neon, Supabase, or local Postgres.
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Better Auth
# Generate a 32+ char random string: `openssl rand -base64 32`
BETTER_AUTH_SECRET=replace-me-with-a-real-secret-string
BETTER_AUTH_URL=http://localhost:3000

# Passkey / WebAuthn relying-party config.
# rpID = registrable domain (no protocol/port); 'localhost' works in dev.
# origin = where the user accesses the web app (scheme + host + port).
PASSKEY_RP_ID=localhost
PASSKEY_RP_NAME=Forecasting
PASSKEY_ORIGIN=http://localhost:5173

# Hono server port
PORT=3000

# ─── Web ─────────────────────────────────────────────────────────────────
# The web/ workspace reads these via Vite. Anything starting with VITE_
# is exposed to the browser.
VITE_API_URL=http://localhost:3000
